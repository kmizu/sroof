{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "sproof",
  "scopeName": "source.sproof",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#tactics" },
    { "include": "#types" },
    { "include": "#constructors" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sproof",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sproof",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "comment.block.sproof" }
          }
        }
      ]
    },
    "keywords": {
      "name": "keyword.control.sproof",
      "match": "\\b(inductive|def|defspec|case|match|by|program|fun)\\b"
    },
    "tactics": {
      "name": "keyword.other.tactic.sproof",
      "match": "\\b(trivial|triv|assume|apply|simplify|simp|induction|induct|sorry|have|calc|ring)\\b"
    },
    "types": {
      "name": "support.type.sproof",
      "match": "\\b(Type|Type0|Type1|Type2|Pi)\\b"
    },
    "constructors": {
      "name": "entity.name.tag.sproof",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\.[a-z][a-zA-Z0-9_]*\\b"
    },
    "strings": {
      "name": "string.quoted.double.sproof",
      "begin": "\"",
      "end": "\""
    },
    "numbers": {
      "name": "constant.numeric.sproof",
      "match": "\\b[0-9]+\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.sproof",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.equals.sproof",
          "match": "(?<![=!<>])=(?![=>])"
        },
        {
          "name": "keyword.operator.colon.sproof",
          "match": ":"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.sproof",
      "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
    }
  }
}

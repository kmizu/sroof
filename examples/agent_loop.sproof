// agent_loop.sproof
// Proof targets for the LLM proof agent loop.

inductive Nat {
  case zero: Nat
  case succ(n: Nat): Nat
}

def plus(n: Nat, m: Nat): Nat {
  match n {
    case Nat.zero    => m
    case Nat.succ(k) => Nat.succ(plus(k, m))
  }
}

def mult(n: Nat, m: Nat): Nat {
  match n {
    case Nat.zero    => Nat.zero
    case Nat.succ(k) => plus(m, mult(k, m))
  }
}

// (1) plus(n, 0) = n  — induction; succ case: simplify IH
defspec plus_zero(n: Nat): plus(n, Nat.zero) = n {
  by induction n {
    case zero    => trivial
    case succ k ih => simplify [ih]
  }
}

// (2) plus(0, n) = n  — definitionally trivial
defspec plus_zero_left(n: Nat): plus(Nat.zero, n) = n {
  by trivial
}

// (3) plus(succ(n), m) = succ(plus(n, m))  — definitionally trivial
defspec plus_succ_left(n: Nat, m: Nat): plus(Nat.succ(n), m) = Nat.succ(plus(n, m)) {
  by trivial
}

// (4) mult(n, 0) = 0  — induction; succ case: simplify IH
defspec mult_zero(n: Nat): mult(n, Nat.zero) = Nat.zero {
  by induction n {
    case zero    => trivial
    case succ k ih => simplify [ih]
  }
}
